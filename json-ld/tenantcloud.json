  "url": "https://www.tenantcloud.com",
  "applicationCategory": "BusinessApplication",
  "applicationSubCategory": "Property Management Software",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "url": "https://www.tenantcloud.com/pricing"
  },
